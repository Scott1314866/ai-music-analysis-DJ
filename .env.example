# ─── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/claudio-fm

# ─── JWT Authentication ───────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── LLM API (OpenAI-compatible: DeepSeek, OpenAI, Claude, etc.) ──
LLM_API_KEY=sk-your-api-key
LLM_API_BASE=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# ─── NetEase Cloud Music (optional) ──────────────────
# Get MUSIC_U from browser cookies after logging into music.163.com
NETEASE_MUSIC_U=your-music-u-cookie-value
NETEASE_API_BASE=http://localhost:3000
